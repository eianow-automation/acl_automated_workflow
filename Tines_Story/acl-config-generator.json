    {
      "type": "Agents::EventTransformationAgent",
      "name": "Render ACL Config",
      "disabled": false,
      "description": null,
      "guid": "f26d3c8fd9bad537d208e58d12414948",
      "origin_story_identifier": "cloud:32fe9314839fbcf70621f74b47308e5d:8fa87ab09ca41c9821d37e0fba756b3c",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "acl_output": "=APPEND(\"--- Generated ACL ---\\n\\n\", build_acl_lines_per_ip.acl_header, \"\\n\\n\", build_acl_lines_per_ip.remark_dns, \"\\n\", JOIN(MAP_LAMBDA(build_acl_lines_per_ip.dns_ips, LAMBDA(ip, APPEND(\"  permit udp any host \", ip, \" eq domain\\n  permit tcp any host \", ip, \" eq domain\"))), \"\\n\"), \"\\n\\n\", build_acl_lines_per_ip.remark_dhcp, \"\\n\", JOIN(MAP_LAMBDA(build_acl_lines_per_ip.dns_ips, LAMBDA(ip, APPEND(\"  permit udp any eq bootpc host \", ip, \" eq bootps\\n  permit udp host \", ip, \" eq bootps any eq bootpc\"))), \"\\n\"), \"\\n\\n\", build_acl_lines_per_ip.remark_ssh, \"\\n\", JOIN(MAP_LAMBDA(build_acl_lines_per_ip.dns_ips, LAMBDA(ip, APPEND(\"  permit tcp any host \", ip, \" eq 22\\n  permit tcp any host \", ip, \" eq 443\"))), \"\\n\"), \"\\n\\n\", build_acl_lines_per_ip.remark_icmp, \"\\n\", JOIN(MAP_LAMBDA(build_acl_lines_per_ip.dns_ips, LAMBDA(ip, APPEND(\"  permit icmp any host \", ip))), \"\\n\"), \"\\n\\n\", build_acl_lines_per_ip.remark_deny, \"\\n\", build_acl_lines_per_ip.deny_line)",
          "dns_ips": "<<build_acl_lines_per_ip.dns_ips>>",
          "generated_at": "<<build_acl_lines_per_ip.generated_at>>",
          "source": "local file"
        }
      },
