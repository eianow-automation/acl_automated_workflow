    {
      "type": "Agents::EventTransformationAgent",
      "name": "Build ACL Lines Per IP",
      "disabled": false,
      "description": null,
      "guid": "9667f716ebe0a5ce834ea3304a65417b",
      "origin_story_identifier": "cloud:32fe9314839fbcf70621f74b47308e5d:8fa87ab09ca41c9821d37e0fba756b3c",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "acl_header": "ip access-list extended FILTER-IN",
          "deny_line": "  deny ip any any log",
          "dns_ips": "=IF(IS_PRESENT(page_action.body.long_text), SPLIT(STRIP(page_action.body.long_text), \"\\n\"), receive_ip_list.body.dns_ips)",
          "dns_lines": "=IF(IS_PRESENT(page_action.body.long_text), page_action.body.long_text, JOIN(receive_ip_list.body.dns_ips, \"\\n\"))",
          "generated_at": "=DATE(\"now\", \"%Y-%m-%dT%H:%M:%SZ\", \"UTC\")",
          "remark_deny": "  remark Explicit deny everything else",
          "remark_dhcp": "  remark Allow DHCP (client <-> server)",
          "remark_dns": "  remark Allow DNS (UDP/TCP 53) to DNS/DHCP servers",
          "remark_icmp": "  remark Allow ICMP to the servers",
          "remark_ssh": "  remark Allow SSH and HTTPS to the servers"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
